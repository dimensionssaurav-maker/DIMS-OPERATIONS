# ============================================================
# FurniTrack ERP — Environment Variables
# ============================================================
# Copy this file to .env and fill in your Supabase credentials
# cp .env.example .env

# Get these from: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── HOW TO GET THESE VALUES ──────────────────────────────────
# 1. Go to https://supabase.com and create a free account
# 2. Click "New Project" → choose a name and password
# 3. Once created, go to: Settings (gear icon) → API
# 4. Copy "Project URL" → paste as VITE_SUPABASE_URL
# 5. Copy "anon public" key → paste as VITE_SUPABASE_ANON_KEY
# 6. Then run the SQL in supabase/schema.sql in the SQL Editor
#
# ── FOR VERCEL DEPLOYMENT ────────────────────────────────────
# In Vercel dashboard: Settings → Environment Variables
# Add both variables above with your real values
# Redeploy after adding them
#
# ── WITHOUT SUPABASE ─────────────────────────────────────────
# Leave these blank — app will use localStorage automatically
# Data will save in the browser but reset if you clear cache
